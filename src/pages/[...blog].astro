---
// @ts-nocheck
import merge from 'lodash.merge';

import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';

import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';

export const prerender = true;

export async function getStaticPaths() {
  const paths = (await getStaticPathsBlogPost()) as any[];
  return paths.map((path) => ({
    params: {
      blog: path.params.blog.replaceAll('blog/', '').replace(/\/$/, '') || undefined,
    },
    props: { post: path.props.post },
  }));
}

const { post } = Astro.props as any;

if (!post) {
  return Astro.redirect('/404');
}

// MENGGUNAKAN METODE RENDER BAWAAN POST (LEBIH STABIL DI ASTROWIND)
const { Content } = await post.render();

const image = await findImage(post.image);
const url = getCanonical(getPermalink(post.permalink, 'post'));

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: { index: blogPostRobots?.index, follow: blogPostRobots?.follow },
    openGraph: { 
      type: 'article',
      images: image ? [{ url: image }] : undefined,
    },
  },
  post.metadata || {}
);
---

<Layout metadata={metadata}>
  <SinglePost post={{ ...post, image }} url={url}>
    {Content ? <Content /> : <Fragment set:html={post.content || ''} />}
  </SinglePost>
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>