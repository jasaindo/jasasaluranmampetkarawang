---
// @ts-nocheck
import merge from 'lodash.merge';
import { render } from 'astro:content';

import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';

import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';

export const prerender = true;

export async function getStaticPaths() {
  const paths = await getStaticPathsBlogPost();
  
  return paths.map((path) => ({
    // SINKRONISASI: Harus 'blog' karena nama file Anda [...blog].astro
    params: { 
      blog: path.params.blog || path.params.post 
    }, 
    props: { 
      post: path.props.post 
    },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/404');
}

const rendered = await render(post);
const { Content } = rendered;

// Load image secara asinkron
const image = await findImage(post.image);

// getPermalink() akan otomatis ke root karena BLOG_BASE sudah kosong
const url = getCanonical(getPermalink(post.permalink));

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: { 
      index: blogPostRobots?.index ?? true, 
      follow: blogPostRobots?.follow ?? true 
    },
    openGraph: { 
      type: 'article',
      ...(image ? { images: [{ url: typeof image === 'object' ? image.src : image }] } : {}),
    },
  },
  post.metadata || {}
);
---

<Layout metadata={metadata}>
  <SinglePost post={{ ...post, image }} url={url}>
    <Content />
  </SinglePost>
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>