---
import { render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import { getStaticPathsBlogPost } from '~/utils/blog';
import { getCanonical, getPermalink } from '~/utils/permalinks';

export const prerender = true;

export async function getStaticPaths() {
  const paths = await getStaticPathsBlogPost();
  return paths.map((path) => ({
    // SINKRONISASI: Gunakan 'post' sesuai nama file [...post].astro
    params: { 
      post: path.params.blog || path.params.post || path.params.slug 
    }, 
    props: { post: path.props.post },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/404');
}

// Render konten secara asinkron (WAJIB ditunggu/await agar konten muncul di build)
const { Content } = await render(post);

const url = getCanonical(getPermalink(post.permalink, 'post'));
---

<Layout metadata={post.metadata}>
  <SinglePost post={post} url={url}>
    <Content />
  </SinglePost>
</Layout>