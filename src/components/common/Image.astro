---
import type { HTMLAttributes } from 'astro/types';
import { findImage } from '~/utils/images';
import {
  getImagesOptimized,
  astroAssetsOptimizer,
  unpicOptimizer,
  isUnpicCompatible,
  type ImageProps,
} from '~/utils/images-optimization';

type Props = ImageProps;
type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

const props = Astro.props;

if (props.alt === undefined || props.alt === null) {
  throw new Error('Image "alt" property is required.');
}

// Konversi string ke number untuk keamanan Astro 5
if (typeof props.width === 'string') {
  props.width = parseInt(props.width);
}

if (typeof props.height === 'string') {
  props.height = parseInt(props.height);
}

// Default values
if (!props.loading) {
  props.loading = 'lazy';
}

if (!props.decoding) {
  props.decoding = 'async';
}

// PERBAIKAN: Tambahkan inferSize jika height tidak ditentukan
// Ini adalah kunci untuk memperbaiki error MissingImageDimension
const modifiedProps = {
  ...props,
  inferSize: props.inferSize ?? (!props.height),
};

const _image = await findImage(props.src);

let image: ImageType | undefined = undefined;

if (
  typeof _image === 'string' &&
  (_image.startsWith('http://') || _image.startsWith('https://')) &&
  isUnpicCompatible(_image)
) {
  image = await getImagesOptimized(_image, modifiedProps, unpicOptimizer);
} else if (_image) {
  // Gunakan modifiedProps yang mengandung inferSize
  image = await getImagesOptimized(_image, modifiedProps, astroAssetsOptimizer);
}
---

{
  !image ? (
    <Fragment />
  ) : (
    <img src={image.src} crossorigin="anonymous" referrerpolicy="no-referrer" {...image.attributes} />
  )
}